(
    version: "phase42",
    shared_pixel_editor_core: true,
    static_canvas_policy: "Tool drawers and side panels may expand, but the tile/asset viewport anchor must not move.",
    primary_tool_rail: [
        "select",
        "pan",
        "pencil",
        "eraser",
        "fill",
        "picker",
        "line",
        "shape",
        "stamp",
        "layers",
    ],
    expandable_tool_drawers: [
        (
            tool: "pencil",
            drawer_opens_to: "right_of_primary_tool_rail",
            collapse_behavior: "click_active_tool_again",
            entries: [
                "1px pencil",
                "square brush",
                "circle brush",
                "line brush",
                "dither brush",
                "replace-color brush",
                "mirror-aware brush",
                "stamp brush",
                "pattern brush",
            ],
        ),
        (
            tool: "eraser",
            drawer_opens_to: "right_of_primary_tool_rail",
            collapse_behavior: "click_active_tool_again",
            entries: [
                "1px eraser",
                "square eraser",
                "alpha eraser",
                "color-target eraser",
            ],
        ),
        (
            tool: "fill",
            drawer_opens_to: "right_of_primary_tool_rail",
            collapse_behavior: "click_active_tool_again",
            entries: [
                "contiguous fill",
                "global replace fill",
                "threshold fill",
                "pattern fill",
            ],
        ),
    ],
    zoom_controls: (
        mouse_wheel_zoom: true,
        middle_mouse_pan: true,
        space_drag_pan: true,
        presets: ["fit", "100%", "200%", "400%", "800%"],
        pixel_grid_toggle: true,
        center_guides_toggle: true,
        tile_bounds_toggle: true,
    ),
    workspaces_using_core: [
        "Assets / Tile Editor",
        "Assets / Atlas Editor",
        "Assets / Atlas Compare Import",
        "Assets / Props Objects",
        "Character / Mannequin",
        "Character / Paperdoll Layers",
        "Character / Equipment Overlays",
        "Animation / Frame Editor",
    ],
)
