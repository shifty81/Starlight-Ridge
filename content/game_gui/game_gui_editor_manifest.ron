GameGuiEditorManifest(
    phase: "phase55b_game_gui_editor_contract",
    screens: [
        (
            id: "hud_main",
            display_name: "Main HUD",
            category: "hud",
            responsibility: "Time, season, stamina, health, wallet, toolbelt, and contextual prompts.",
            target_viewports: ["1280x720", "1920x1080", "2560x1440"],
            validation: ["safe_area", "controller_focus", "text_overflow", "runtime_bindings"],
        ),
        (
            id: "dialogue_default",
            display_name: "Default Dialogue Panel",
            category: "dialogue",
            responsibility: "Portrait, speaker name, dialogue body, response choices, and typewriter state.",
            target_viewports: ["1280x720", "1920x1080", "2560x1440"],
            validation: ["text_overflow", "choice_focus", "portrait_binding", "localization_budget"],
        ),
        (
            id: "inventory_main",
            display_name: "Inventory",
            category: "menu",
            responsibility: "Item grid, equipment slots, details pane, sort/filter controls, and controller navigation.",
            target_viewports: ["1280x720", "1920x1080", "2560x1440"],
            validation: ["controller_focus", "action_bindings", "text_overflow", "empty_state"],
        ),
        (
            id: "pause_menu",
            display_name: "Pause Menu",
            category: "menu",
            responsibility: "Resume, save, settings, return to title, and quit flow.",
            target_viewports: ["1280x720", "1920x1080", "2560x1440"],
            validation: ["controller_focus", "destructive_action_confirm", "safe_area"],
        ),
    ],
    style_tokens: [
        "panel_base",
        "panel_raised",
        "button_primary",
        "button_secondary",
        "text_body",
        "text_caption",
        "accent_focus",
        "warning",
    ],
    runtime_bindings: [
        "player.health",
        "player.stamina",
        "player.wallet",
        "world.time_of_day",
        "world.season",
        "inventory.selected_item",
        "dialogue.current_node",
    ],
)
