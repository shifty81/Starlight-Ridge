(
    id: "phase21_animation_editor_timeline_events",
    display_name: "Phase 21 Animation Editor Timeline, Events, Sockets, and Hitboxes",
    default_frame_ms: 140,
    timeline_schemas: [
        (
            id: "gameplay_timeline_v1",
            display_name: "Gameplay Timeline v1",
            supported_loop_modes: ["once", "loop", "ping_pong", "hold_last"],
            required_tracks: ["frames", "events", "sockets", "hitboxes", "audio", "effects"],
            marker_kinds: ["play_sound", "spawn_effect", "apply_tool_action", "apply_damage", "emit_footstep", "lock_player_input", "unlock_player_input"],
        ),
        (
            id: "water_preview_timeline_v1",
            display_name: "Water Preview Timeline v1",
            supported_loop_modes: ["loop", "ping_pong"],
            required_tracks: ["frames", "season", "random_start_offset", "shore_overlay"],
            marker_kinds: ["water_loop", "shore_foam", "sparkle_overlay"],
        ),
    ],
    animation_clips: [
        (
            id: "player_walk_down",
            display_name: "Player Walk Down",
            target_kind: "player",
            target_id: "player",
            direction: "down",
            loop_mode: "loop",
            frames: [
                (index: 0, sprite_sheet_id: "phase5_entities", sprite_id: "player_front_idle", duration_ms: 120, events: []),
                (index: 1, sprite_sheet_id: "phase5_entities", sprite_id: "player_front_walk_1", duration_ms: 120, events: [(id: "walk_down_footstep_l", frame_index: 1, event_kind: "emit_footstep", payload: "grass_left", required: false)]),
                (index: 2, sprite_sheet_id: "phase5_entities", sprite_id: "player_front_walk_2", duration_ms: 120, events: []),
                (index: 3, sprite_sheet_id: "phase5_entities", sprite_id: "player_front_walk_3", duration_ms: 120, events: [(id: "walk_down_footstep_r", frame_index: 3, event_kind: "emit_footstep", payload: "grass_right", required: false)]),
            ],
        ),
        (
            id: "player_walk_left",
            display_name: "Player Walk Left",
            target_kind: "player",
            target_id: "player",
            direction: "left",
            loop_mode: "loop",
            frames: [
                (index: 0, sprite_sheet_id: "phase5_entities", sprite_id: "player_left_idle", duration_ms: 120, events: []),
                (index: 1, sprite_sheet_id: "phase5_entities", sprite_id: "player_left_walk_1", duration_ms: 120, events: [(id: "walk_left_footstep_l", frame_index: 1, event_kind: "emit_footstep", payload: "grass_left", required: false)]),
                (index: 2, sprite_sheet_id: "phase5_entities", sprite_id: "player_left_walk_2", duration_ms: 120, events: []),
                (index: 3, sprite_sheet_id: "phase5_entities", sprite_id: "player_left_walk_3", duration_ms: 120, events: [(id: "walk_left_footstep_r", frame_index: 3, event_kind: "emit_footstep", payload: "grass_right", required: false)]),
            ],
        ),
        (
            id: "player_walk_right",
            display_name: "Player Walk Right",
            target_kind: "player",
            target_id: "player",
            direction: "right",
            loop_mode: "loop",
            frames: [
                (index: 0, sprite_sheet_id: "phase5_entities", sprite_id: "player_right_idle", duration_ms: 120, events: []),
                (index: 1, sprite_sheet_id: "phase5_entities", sprite_id: "player_right_walk_1", duration_ms: 120, events: [(id: "walk_right_footstep_l", frame_index: 1, event_kind: "emit_footstep", payload: "grass_left", required: false)]),
                (index: 2, sprite_sheet_id: "phase5_entities", sprite_id: "player_right_walk_2", duration_ms: 120, events: []),
                (index: 3, sprite_sheet_id: "phase5_entities", sprite_id: "player_right_walk_3", duration_ms: 120, events: [(id: "walk_right_footstep_r", frame_index: 3, event_kind: "emit_footstep", payload: "grass_right", required: false)]),
            ],
        ),
        (
            id: "player_walk_up",
            display_name: "Player Walk Up",
            target_kind: "player",
            target_id: "player",
            direction: "up",
            loop_mode: "loop",
            frames: [
                (index: 0, sprite_sheet_id: "phase5_entities", sprite_id: "player_back_idle", duration_ms: 120, events: []),
                (index: 1, sprite_sheet_id: "phase5_entities", sprite_id: "player_back_walk_1", duration_ms: 120, events: [(id: "walk_up_footstep_l", frame_index: 1, event_kind: "emit_footstep", payload: "grass_left", required: false)]),
                (index: 2, sprite_sheet_id: "phase5_entities", sprite_id: "player_back_walk_2", duration_ms: 120, events: []),
                (index: 3, sprite_sheet_id: "phase5_entities", sprite_id: "player_back_walk_3", duration_ms: 120, events: [(id: "walk_up_footstep_r", frame_index: 3, event_kind: "emit_footstep", payload: "grass_right", required: false)]),
            ],
        ),
        (
            id: "player_hoe_down_timeline",
            display_name: "Player Hoe Down Timeline",
            target_kind: "player",
            target_id: "player",
            direction: "down",
            loop_mode: "once",
            frames: [
                (index: 0, sprite_sheet_id: "phase5_entities", sprite_id: "player_front_idle", duration_ms: 90, events: [(id: "hoe_down_lock_input", frame_index: 0, event_kind: "lock_player_input", payload: "tool_use", required: true)]),
                (index: 1, sprite_sheet_id: "phase5_entities", sprite_id: "player_front_walk_1", duration_ms: 110, events: [(id: "hoe_down_raise_sound", frame_index: 1, event_kind: "play_sound", payload: "tool_raise", required: false)]),
                (index: 2, sprite_sheet_id: "phase5_entities", sprite_id: "player_front_walk_2", duration_ms: 130, events: [(id: "hoe_down_apply", frame_index: 2, event_kind: "apply_tool_action", payload: "hoe_tile_in_front", required: true), (id: "hoe_down_spawn_dust", frame_index: 2, event_kind: "spawn_effect", payload: "impact_puff", required: false)]),
                (index: 3, sprite_sheet_id: "phase5_entities", sprite_id: "player_front_idle", duration_ms: 90, events: [(id: "hoe_down_unlock_input", frame_index: 3, event_kind: "unlock_player_input", payload: "tool_use", required: true)]),
            ],
        ),
        (
            id: "seagull_idle_flap",
            display_name: "Seagull Idle Flap",
            target_kind: "sprite",
            target_id: "seagull_idle",
            direction: "none",
            loop_mode: "loop",
            frames: [
                (index: 0, sprite_sheet_id: "oceans_heart_bridge_phase17", sprite_id: "seagull_idle", duration_ms: 220, events: []),
                (index: 1, sprite_sheet_id: "oceans_heart_bridge_phase17", sprite_id: "seagull_flap_up", duration_ms: 140, events: []),
                (index: 2, sprite_sheet_id: "oceans_heart_bridge_phase17", sprite_id: "seagull_flap_down", duration_ms: 140, events: []),
                (index: 3, sprite_sheet_id: "oceans_heart_bridge_phase17", sprite_id: "seagull_glide", duration_ms: 260, events: []),
            ],
        ),
        (
            id: "impact_puff_short",
            display_name: "Impact Puff Short",
            target_kind: "effect",
            target_id: "impact_puff",
            direction: "none",
            loop_mode: "once",
            frames: [
                (index: 0, sprite_sheet_id: "oceans_heart_bridge_phase17", sprite_id: "impact_puff", duration_ms: 90, events: [(id: "impact_puff_sound", frame_index: 0, event_kind: "play_sound", payload: "soft_impact", required: false)]),
                (index: 1, sprite_sheet_id: "oceans_heart_bridge_phase17", sprite_id: "steam_puff_small", duration_ms: 110, events: []),
            ],
        ),
        (
            id: "shallow_water_loop_tiles",
            display_name: "Shallow Water Loop Tiles",
            target_kind: "water",
            target_id: "shallow_water",
            direction: "none",
            loop_mode: "loop",
            frames: [
                (index: 0, sprite_sheet_id: "base_tiles", sprite_id: "water_shallow", duration_ms: 180, events: [(id: "water_loop_marker", frame_index: 0, event_kind: "water_loop", payload: "shallow", required: false)]),
                (index: 1, sprite_sheet_id: "base_tiles", sprite_id: "water_shallow_v01", duration_ms: 180, events: []),
                (index: 2, sprite_sheet_id: "base_tiles", sprite_id: "water_shallow_v02", duration_ms: 180, events: []),
                (index: 3, sprite_sheet_id: "base_tiles", sprite_id: "water_shallow_v03", duration_ms: 180, events: []),
            ],
        ),
    ],
    directional_groups: [
        (
            id: "player_walk_4dir",
            display_name: "Player Walk 4 Direction",
            directions: [
                (direction: "down", clip_id: "player_walk_down"),
                (direction: "left", clip_id: "player_walk_left"),
                (direction: "right", clip_id: "player_walk_right"),
                (direction: "up", clip_id: "player_walk_up"),
            ],
            mirror_left_from_right: false,
            fallback_direction: "down",
        ),
        (
            id: "player_hoe_down_action",
            display_name: "Player Hoe Down Action",
            directions: [
                (direction: "down", clip_id: "player_hoe_down_timeline"),
            ],
            mirror_left_from_right: false,
            fallback_direction: "down",
        ),
    ],
    socket_profiles: [
        (
            id: "player_walk_hand_and_feet_sockets",
            clip_id: "player_walk_down",
            sockets: [
                (frame_index: 0, socket_id: "right_hand", x: 19, y: 19, required: false),
                (frame_index: 1, socket_id: "left_foot", x: 12, y: 29, required: false),
                (frame_index: 3, socket_id: "right_foot", x: 21, y: 29, required: false),
            ],
        ),
        (
            id: "hoe_down_tool_sockets",
            clip_id: "player_hoe_down_timeline",
            sockets: [
                (frame_index: 0, socket_id: "right_hand", x: 20, y: 18, required: true),
                (frame_index: 1, socket_id: "right_hand", x: 22, y: 14, required: true),
                (frame_index: 2, socket_id: "tool_tip", x: 16, y: 35, required: true),
                (frame_index: 3, socket_id: "right_hand", x: 20, y: 18, required: true),
            ],
        ),
    ],
    hitbox_profiles: [
        (
            id: "hoe_down_tool_hitbox",
            clip_id: "player_hoe_down_timeline",
            boxes: [
                (frame_index: 2, box_kind: "tool_action", x: 0, y: 32, width: 32, height: 32, action: "hoe_tile_in_front"),
                (frame_index: 2, box_kind: "interaction_window", x: 0, y: 32, width: 32, height: 32, action: "allow_soil_change"),
            ],
        ),
        (
            id: "impact_puff_effect_bounds",
            clip_id: "impact_puff_short",
            boxes: [
                (frame_index: 0, box_kind: "effect_bounds", x: 0, y: 0, width: 32, height: 32, action: "visual_only"),
            ],
        ),
    ],
    water_preview_profiles: [
        (
            id: "shallow_water_editor_preview",
            animation_id: "shallow_water_loop_tiles",
            tilemap_width: 5,
            tilemap_height: 3,
            random_start_offset: true,
            show_shore_overlay: true,
            season: "spring",
        ),
        (
            id: "shallow_water_timeline_preview",
            animation_id: "shallow_water_loop_tiles",
            tilemap_width: 4,
            tilemap_height: 4,
            random_start_offset: true,
            show_shore_overlay: false,
            season: "all",
        ),
    ],
    seasonal_animation_sets: [
        (
            id: "player_walk_all_seasons",
            semantic_animation_id: "player_walk",
            spring_clip_id: "player_walk_down",
            summer_clip_id: "player_walk_down",
            fall_clip_id: "player_walk_down",
            winter_clip_id: "player_walk_down",
            fallback_clip_id: "player_walk_down",
        ),
        (
            id: "shallow_water_loop_all_seasons",
            semantic_animation_id: "shallow_water_loop",
            spring_clip_id: "shallow_water_loop_tiles",
            summer_clip_id: "shallow_water_loop_tiles",
            fall_clip_id: "shallow_water_loop_tiles",
            winter_clip_id: "shallow_water_loop_tiles",
            fallback_clip_id: "shallow_water_loop_tiles",
        ),
    ],
    validation_reports: [
        (
            id: "animation_frame_reference_validation",
            severity: "error",
            enabled: true,
            checks: ["frame sprite ids resolve", "frame durations are non-zero", "duplicate frame indices are rejected"],
        ),
        (
            id: "animation_event_validation",
            severity: "error",
            enabled: true,
            checks: ["required gameplay events have payloads", "events are stored on matching frame indices", "tool action events can be paired with hitboxes"],
        ),
        (
            id: "socket_hitbox_validation",
            severity: "warning",
            enabled: true,
            checks: ["required sockets exist on impact frames", "hitboxes reference valid frames", "box dimensions are positive"],
        ),
        (
            id: "seasonal_animation_validation",
            severity: "warning",
            enabled: true,
            checks: ["season variants reference existing clips", "fallback clip exists", "water previews specify a season"],
        ),
    ],
)
