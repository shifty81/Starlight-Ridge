        "Scene Preview",
        "Sprite Bake",
        "Icon Bake",
        "Lighting Studio",
        "Camera Presets",
        "Render Jobs",
    ],
    external_tool_targets: ["Bash", "MagicaVoxel", "Blockbench", "Blender"],
    automation_goals: [
        "Use Bash/Command Runner for cargo, packaging, diagnostics, and pipeline jobs.",
        "Use MagicaVoxel for source VOX props and blocky object drafts.",
        "Use Blockbench for low-poly/block model source assets and glTF/OBJ exports.",
        "Use Blender for sprite/icon/preview baking and high-quality batch renders.",
    ],
    notes: [
        "This is a scaffold contract. It intentionally does not replace the stable 2D map renderer yet.",
        "World data should stay grid-readable while Render and Assets tabs add 3D authoring and bake workflows.",
    ],
)
