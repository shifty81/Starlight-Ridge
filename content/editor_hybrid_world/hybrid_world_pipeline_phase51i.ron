(
    id: "hybrid_world_pipeline_phase51i",
    display_name: "Hybrid 2D/3D World Authoring Pipeline",
    default_render_mode: Hybrid2_5D,
    world_subtabs: [
        "Map Paint",
        "Layers",
        "Height / Elevation",
        "3D Scene Layout",
        "Camera / Presentation",
