(
    version: "phase44",
    purpose: "editor_only_character_studio_contract",
    note: "Loaded by future Character Studio tooling. Kept out of content/metadata so runtime sprite-sheet registry does not try to parse it.",
    scale_classes: [
        (
            id: "small_child",
            display_name: "Small Child",
            world_height_blocks: 1.0,
            target_frame_width_px: 32,
            target_frame_height_px: 32,
            collision_width_blocks: 0.55,
            collision_height_blocks: 0.55,
            foot_anchor_px: (x: 16, y: 31),
            use_case: "young kids / tiny NPCs",
        ),
        (
            id: "tall_child_teen",
            display_name: "Tall Child / Teen",
            world_height_blocks: 1.5,
            target_frame_width_px: 32,
            target_frame_height_px: 48,
            collision_width_blocks: 0.60,
            collision_height_blocks: 0.75,
            foot_anchor_px: (x: 16, y: 47),
            use_case: "older kids, teens, short villagers",
        ),
        (
            id: "standard_adult",
            display_name: "Standard Adult",
            world_height_blocks: 2.0,
            target_frame_width_px: 32,
            target_frame_height_px: 64,
            collision_width_blocks: 0.65,
            collision_height_blocks: 0.85,
            foot_anchor_px: (x: 16, y: 63),
            use_case: "player and most adult NPCs",
        ),
        (
            id: "tall_adult_rig",
            display_name: "Tall Adult / Rig",
            world_height_blocks: 2.25,
            target_frame_width_px: 48,
            target_frame_height_px: 72,
            collision_width_blocks: 0.75,
            collision_height_blocks: 0.95,
            foot_anchor_px: (x: 24, y: 71),
            use_case: "large NPCs, backpacks, future rig/exosuit silhouettes",
        ),
    ],
    paperdoll_layers: [
        "shadow",
        "base_body",
        "under_clothes",
        "shirt",
        "pants",
        "boots",
        "hair_back",
        "face_detail",
        "beard",
        "hair_front",
        "hat",
        "held_tool",
        "backpack_or_rig",
    ],
    equipment_slots: [
        (id: "head", accepts: ["hat", "helmet", "hair_override"]),
        (id: "face", accepts: ["beard", "glasses", "mask"]),
        (id: "torso", accepts: ["shirt", "coat", "armor_torso"]),
        (id: "legs", accepts: ["pants", "skirt", "armor_legs"]),
        (id: "feet", accepts: ["boots", "shoes"]),
        (id: "hands", accepts: ["gloves", "hand_offset"]),
        (id: "tool_hand", accepts: ["tool_socket", "held_item"]),
        (id: "back", accepts: ["backpack", "rig", "cape"]),
        (id: "accessory", accepts: ["ring", "charm", "misc"]),
    ],
    animation_targets: [
        "idle",
        "walk",
        "run",
        "tool_swing",
        "carry",
        "sit",
        "sleep",
        "emote",
    ],
    validation_rules: [
        "every frame must have a bottom-center foot anchor",
        "overlay sheets must match base frame count, directions, and frame dimensions",
        "collision boxes must be separate from sprite draw height",
        "tool-use clips must expose tool sockets and hit timing events",
        "hair, hats, beards, clothing, and rig parts must support per-scale offsets",
    ],
)
