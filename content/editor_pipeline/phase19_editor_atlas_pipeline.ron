(
    id: "phase19_editor_atlas_pipeline",
    display_name: "Phase 19 Terrain Atlas Pipeline",
    tile_size: 32,
    active_season: "spring",
    atlases: [
        (
            id: "terrain_atlas",
            display_name: "Project Terrain Atlas",
            asset_ref: "base_tiles",
            asset_kind: "tileset",
            render_layer: 0,
            editable: true,
            source_role: "canonical_project_atlas",
            allowed_categories: ["terrain", "water", "transition", "object", "seasonal"],
            forbidden_categories: ["character", "ui"],
        ),
    ],
    season_sets: [
        (
            id: "grass_four_season_seed",
            semantic_tile_id: "grass",
            spring: (atlas_id: "terrain_atlas", tile_id: "grass_bright"),
            summer: (atlas_id: "terrain_atlas", tile_id: "grass_bright_v03"),
            fall: (atlas_id: "terrain_atlas", tile_id: "grass_bright_v04"),
            winter: (atlas_id: "terrain_atlas", tile_id: "grass_dark"),
        ),
        (
            id: "sand_four_season_seed",
            semantic_tile_id: "sand",
            spring: (atlas_id: "terrain_atlas", tile_id: "sand"),
            summer: (atlas_id: "terrain_atlas", tile_id: "sand_v01"),
            fall: (atlas_id: "terrain_atlas", tile_id: "sand_v02"),
            winter: (atlas_id: "terrain_atlas", tile_id: "sand_v03"),
        ),
        (
            id: "water_four_season_seed",
            semantic_tile_id: "shallow_water",
            spring: (atlas_id: "terrain_atlas", tile_id: "water_shallow"),
            summer: (atlas_id: "terrain_atlas", tile_id: "water_shallow_v01"),
            fall: (atlas_id: "terrain_atlas", tile_id: "water_shallow_v02"),
            winter: (atlas_id: "terrain_atlas", tile_id: "water_shallow_v03"),
        ),
    ],
    water_animations: [
        (
            id: "shallow_water_idle",
            terrain_id: "shallow_water",
            frames: [
                (atlas_id: "terrain_atlas", tile_id: "water_shallow"),
                (atlas_id: "terrain_atlas", tile_id: "water_shallow_v01"),
                (atlas_id: "terrain_atlas", tile_id: "water_shallow_v02"),
                (atlas_id: "terrain_atlas", tile_id: "water_shallow_v03"),
            ],
            frame_ms: 180,
            loop_mode: "loop",
            render_layer: 3,
            random_start_offset: true,
        ),
    ],
    clipboard_tools: [
        (
            id: "grid_tile_copy_paste",
            display_name: "Grid Tile Copy/Paste",
            snap_to_tile_grid: true,
            mirror_horizontal: true,
            mirror_vertical: true,
            rotate_90: true,
            palette_remap: false,
            assign_metadata_after_paste: true,
        ),
    ],
    validation_checks: [
        (
            id: "atlas_tile_refs_exist",
            severity: "error",
            enabled: true,
            description: "Every editor atlas tile reference must resolve to the active project tileset.",
        ),
        (
            id: "season_variants_have_fallbacks",
            severity: "warning",
            enabled: true,
            description: "Seasonal variants should always have a visible fallback tile.",
        ),
    ],
    game_preview_profiles: [
        (
            id: "spring_editor_preview",
            display_name: "Spring Editor Preview",
            season: "spring",
            show_editor_overlays: true,
            show_collision: false,
            show_water_animation: true,
            show_props: true,
            show_transitions: true,
            day_time_minutes: 720,
        ),
    ],
)
