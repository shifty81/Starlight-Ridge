(
    id: "phase51_worldgen_editor_workflow",
    display_name: "Phase 51 World Graph / Scene Draft Workflow",
    active_world_manifest: "starlight_ridge_world",
    preview_panels: [
        "world_graph_overview",
        "scene_node_list",
        "sub_scene_tree",
        "layer_stack_policy_report",
        "generated_semantic_preview",
        "autotile_handoff_preview",
        "bake_contract_preview",
        "validation_issue_list",
    ],
    bake_steps: [
        "select_scene_node",
        "generate_scene_draft_from_template_seed",
        "write_semantic_scene_draft",
        "write_generated_scene_draft_record",
        "write_bake_contract",
        "run_autotile_resolver_next_phase",
        "preserve_authored_layers",
        "bake_generated_layers_into_scene_files",
    ],
    validation_checks: [
        "world_manifest_has_default_scene",
        "regions_reference_existing_scenes",
        "scene_connections_reference_existing_targets",
        "scene_layer_ids_unique",
        "protected_layers_are_not_regenerated",
        "derived_layers_are_rebuildable",
        "scene_bake_target_is_present",
    ],
)
