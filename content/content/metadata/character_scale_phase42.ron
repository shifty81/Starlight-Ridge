(
    version: "phase42",
    tile_reference: (
        tile_width_px: 32,
        tile_height_px: 32,
        notes: "Use one world block/tile as the gameplay scale unit. Character rendering may exceed collision height, but foot anchors must align to tile grid.",
    ),
    scale_ladder: [
        (
            id: "child_small",
            display_name: "Small Child",
            world_height_tiles: 1.0,
            target_frame_width_px: 32,
            target_frame_height_px: 32,
            collision_width_tiles: 0.55,
            collision_height_tiles: 0.55,
            foot_anchor_px: (x: 16, y: 31),
            use_case: "young child / tiny NPC / scale reference",
        ),
        (
            id: "child_tall",
            display_name: "Tall Child / Teen",
            world_height_tiles: 1.5,
            target_frame_width_px: 32,
            target_frame_height_px: 48,
            collision_width_tiles: 0.60,
            collision_height_tiles: 0.70,
            foot_anchor_px: (x: 16, y: 47),
            use_case: "older child, teen, short adult, stylized villager variant",
        ),
        (
            id: "adult_standard",
            display_name: "Standard Adult",
            world_height_tiles: 2.0,
            target_frame_width_px: 32,
            target_frame_height_px: 64,
            collision_width_tiles: 0.65,
            collision_height_tiles: 0.75,
            foot_anchor_px: (x: 16, y: 63),
            use_case: "main player, adult NPC, common paperdoll base",
        ),
        (
            id: "adult_tall_or_rig",
            display_name: "Tall Adult / Equipped Rig",
            world_height_tiles: 2.25,
            target_frame_width_px: 48,
            target_frame_height_px: 72,
            collision_width_tiles: 0.75,
            collision_height_tiles: 0.85,
            foot_anchor_px: (x: 24, y: 71),
            use_case: "large NPC, heavy clothing, backpack, future exosuit or rig silhouette",
        ),
    ],
    rendering_contract: (
        anchor_model: "bottom_center_feet",
        sort_key: "feet_y_then_layer_then_entity_id",
        layer_order: [
            "shadow",
            "body_base",
            "underwear",
            "eyes",
            "hair_back",
            "beard",
            "shirt",
            "pants",
            "shoes",
            "hair_front",
            "hat",
            "held_tool_back",
            "held_tool_front",
            "accessory",
            "backpack_or_rig",
            "effect",
        ],
        notes: "Do not stretch a 1-block child into a 2-block adult. Author separate base frames per scale class. Overlay items can share logical slots but need per-scale offsets.",
    ),
    editor_requirements: (
        character_studio_tabs: [
            "Mannequin",
            "Paperdoll Layers",
            "Equipment / Overlays",
            "Animation Preview",
            "Scale Validator",
            "Export / Metadata",
        ],
        validators: [
            "all_frames_same_canvas_size_per_scale",
            "foot_anchor_consistent_per_direction",
            "overlay_offsets_exist_for_each_scale_and_direction",
            "adult_player_base_uses_2_tile_height",
            "child_scale_variants_do_not_reuse_adult_collision_capsule",
        ],
    ),
)
