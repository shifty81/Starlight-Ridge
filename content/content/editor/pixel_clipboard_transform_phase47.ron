(
    id: "pixel_clipboard_transform_phase47",
    display_name: "Pixel Clipboard Transform Workflow Phase 47",
    purpose: "User-friendly copy, mirror, rotate, and viewport copy workflow for pixel/atlas editing.",
    copy_scopes: [
        "selection",
        "current_tile",
        "entire_viewport",
        "atlas_region",
    ],
    paste_transforms: [
        "normal",
        "mirror_horizontal",
        "mirror_vertical",
        "mirror_both",
        "rotate_90",
        "rotate_180",
        "rotate_270",
    ],
    ui_rules: [
        "copy and paste controls stay in the left tool/options region",
        "paste transform changes the preview and next paste operation only",
        "source clipboard pixels are never mutated by mirror or rotate preview",
        "center pixel/asset viewport remains anchored and does not slide when drawers expand",
        "copy entire viewport captures the currently visible canvas framing for fast corner/edge reuse",
        "rotated paste should snap to the current tile grid before commit",
    ],
    implementation_stages: [
        "phase47_ui_state_and_checkpoint",
        "phase48_real_clipboard_image_buffer",
        "phase49_pixel_commit_undo_redo",
        "phase50_atlas_region_copy_auto_expand",
    ],
)
